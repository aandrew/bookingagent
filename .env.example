# --- Kooroo ---
# Base URL of the booking site. Override only if you point at a different deployment.
KOOROO_BASE_URL=https://kooroora.asn.au

# --- Spike (Playwright) ---
# Credentials used by `npm run spike` to log in once and capture the HAR.
KOOROO_SPIKE_USER=
KOOROO_SPIKE_PASS=
# Set to 1 to run the spike with a visible browser (useful for debugging).
# SPIKE_HEADED=1

# --- Admin dashboard ---
# Single admin user. Change before deploying.
ADMIN_USER=admin
ADMIN_PASS=change-me-please

# Long random string used to sign session cookies (run: openssl rand -hex 48)
SESSION_SECRET=replace-with-a-long-random-string

# Where SQLite + HAR artefacts live inside the container.
DATA_DIR=/app/data

# --- Behaviour ---
# Legacy availability-poll cron (currently unused; kept for reference).
POLL_CRON=*/2 * * * *
# Legacy */10 session-probe cron (disabled in v3.1; per-recurring timers take over).
SESSION_PROBE_CRON=*/10 * * * *
# v3.1: probe each account's session this many minutes BEFORE the existing
# warmup, so a Playwright re-login has time to complete before the fire.
# A probe runs once per recurring, at T_fire - LEAD_MINUTES_BEFORE_FIRE - this.
SESSION_CHECK_OFFSET_MINUTES=5
# Default days ahead to book when a watch is "scheduled".
DEFAULT_LEAD_DAYS=7
# Lead minutes (warm before the fire). v3: global default; per-recurring overrides removed.
LEAD_MINUTES_BEFORE_FIRE=5
# How many days back the audit log is retained.
AUDIT_RETENTION_DAYS=30
# Set to "true" to store full request/response bodies in the audit log.
AUDIT_FULL_BODIES=true
# --- Backups (v3) ---
# Daily cron inside the container for the hot backup job.
BACKUP_CRON=30 2 * * *
# Keep this many days of backups (oldest are deleted).
BACKUP_RETENTION_DAYS=30

# --- Multi-account smoke test (test/multi_account_smoke.js) ---
# Test-only credentials. NEVER set these in production unless you also accept
# that the test will exercise those accounts against the live Kooroo API.
# Both pairs should be distinct Kooroo accounts; the test asserts that two
# accounts on the same recurring time slot get auto-allocated different courts.
KOOROO_TEST_USER_1=
KOOROO_TEST_PASS_1=
KOOROO_TEST_USER_2=
KOOROO_TEST_PASS_2=
# When the smoke test is run, it hits the dashboard's login URL (default below).
# Override if you proxy it via Caddy or a different host.
KOOROO_TEST_BASE_URL=http://127.0.0.1:3000
KOOROO_TEST_ADMIN_USER=
KOOROO_TEST_ADMIN_PASS=

  </main>
  <footer style="display: flex; justify-content: space-between; align-items: center; padding: 8px 18px; font-size: 11px; color: var(--muted); border-top: 1px solid var(--line); background: var(--panel); margin-top: 18px;">
    <span>v3.6 — Kooroora Booking Agent</span>
    <span id="live-indicator" title="Live updates status" style="display: inline-flex; align-items: center; gap: 6px; cursor: default;">
      <span id="live-dot" style="width: 8px; height: 8px; border-radius: 50%; background: var(--muted); display: inline-block;"></span>
      <span id="live-text">offline</span>
    </span>
  </footer>
  <script src="/public/live.js"></script>
  <script>
    // v4: live indicator status updater. Subscribes to KoorooLive's
    // _live_status pseudo-event (fires on every event + on connect/disconnect)
    // and updates the footer dot + text + tooltip.
    (function setupLiveIndicator() {
      if (typeof KoorooLive === 'undefined') return;
      const dot = document.getElementById('live-dot');
      const text = document.getElementById('live-text');
      const ind = document.getElementById('live-indicator');
      if (!dot || !text || !ind) return;
      function fmtAge(ms) {
        if (ms <= 0) return 'never';
        var s = Math.floor(ms / 1000);
        if (s < 60) return s + 's ago';
        var m = Math.floor(s / 60);
        if (m < 60) return m + 'm ago';
        var h = Math.floor(m / 60);
        return h + 'h ago';
      }
      KoorooLive.on('_live_status', function (snap) {
        if (snap.connected) {
          if (snap.stale) {
            dot.style.background = 'var(--warn)';
            text.textContent = 'live (stale)';
          } else {
            dot.style.background = 'var(--accent)';
            text.textContent = 'live';
          }
        } else if (snap.reconnectAttempt > 0) {
          dot.style.background = 'var(--warn)';
          text.textContent = 'reconnecting';
        } else {
          dot.style.background = 'var(--muted)';
          text.textContent = 'offline';
        }
        ind.title = snap.connected
          ? 'Live updates connected.\nLast event: ' + fmtAge(Date.now() - snap.lastEventTime) + '.'
          : 'Live updates not connected. The page still works (static). Reconnect attempt: ' + snap.reconnectAttempt + '.';
      });
    })();
  </script>
  <script>
    async function jsonReq(url, opts) {
      const r = await fetch(url, { headers: { 'content-type': 'application/json' }, ...opts });
      if (!r.ok) {
        let msg = r.statusText;
        try { const j = await r.json(); msg = j.error || msg; } catch {}
        throw new Error(msg);
      }
      return r.json();
    }
    async function bookNowBtn(id) {
      try { const r = await jsonReq('/api/recurring/' + id + '/book-now', { method: 'POST' }); alert('Book: ' + JSON.stringify(r)); location.reload(); }
      catch (e) { alert(e.message); }
    }
    // backward-compat alias used by older templates
    async function fireNowBtn(id) { return bookNowBtn(id); }
    async function dismissError(id) {
      try { await jsonReq('/api/recurring/' + id + '/dismiss-error', { method: 'POST' }); location.reload(); }
      catch (e) { alert(e.message); }
    }
    async function toggleRecurring(id, enabled) {
      try { await jsonReq('/api/recurring/' + id, { method: 'PATCH', body: JSON.stringify({ enabled }) }); location.reload(); }
      catch (e) { alert(e.message); }
    }
    // Live countdown refresh: walk every [data-fire-at] element and update.
    (function tickCountdowns() {
      const els = document.querySelectorAll('[data-fire-at]');
      if (!els.length) return;
      const now = Date.now();
      els.forEach(el => {
        const t = parseInt(el.dataset.fireAt, 10);
        if (!Number.isFinite(t)) return;
        const d = t - now;
        if (d <= 0) { el.textContent = 'now'; el.classList.add('warn'); return; }
        const days = Math.floor(d / 86_400_000);
        const hours = Math.floor((d % 86_400_000) / 3_600_000);
        const mins = Math.floor((d % 3_600_000) / 60_000);
        const secs = Math.floor((d % 60_000) / 1000);
        el.textContent = `${days}d ${String(hours).padStart(2,'0')}:${String(mins).padStart(2,'0')}:${String(secs).padStart(2,'0')}`;
      });
      setTimeout(tickCountdowns, 1000);
    })();

    // Auto-dismiss .flash.auto-dismiss elements after 4 seconds (CSS handles fade)
    (function autoDismissFlashes() {
      const els = document.querySelectorAll('.flash.auto-dismiss');
      els.forEach(el => setTimeout(() => el.remove(), 4100));
    })();
  </script>
</body>
</html>

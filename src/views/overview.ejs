<%- include('partials/header', { title: 'Overview' }) %>
<div class="row">
  <div class="panel">
    <h2>Upcoming bookings (next 5)</h2>
    <table>
      <thead><tr><th>Label</th><th>Account</th><th>Pattern</th><th>Next attempt</th><th>Action</th></tr></thead>
      <tbody>
      <% recurringRows.filter(r => r.enabled).sort((a,b) => new Date(a.next_fire_at) - new Date(b.next_fire_at)).slice(0,5).forEach(function(r) { %>
        <tr>
          <td><a href="/recurring/<%= r.id %>"><%= r.label %></a></td>
          <td>#<%= r.account_id %></td>
          <td class="muted">Court <%= r.court_pref %> <%= ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][r.day_of_week] %> <%= r.time %></td>
          <td><span class="countdown" data-fire-at="<%= new Date(r.next_fire_at).getTime() %>">…</span></td>
          <td><span class="pill <%= r.first_occurrence_action === 'book_now' ? 'warn' : 'info' %>"><%= r.first_occurrence_action === 'book_now' ? 'booking' : (r.first_occurrence_action || '—') %></span></td>
        </tr>
      <% }) %>
      <% if (!recurringRows.length) { %><tr><td colspan="5" class="muted">No recurring bookings yet — add one in <a href="/recurring">Recurring</a>.</td></tr><% } %>
      </tbody>
    </table>
  </div>

  <div class="panel">
    <h2>Recent booking attempts</h2>
    <table>
      <thead><tr><th>Time</th><th>Recurring</th><th>Status</th><th>Court</th><th>Latency</th></tr></thead>
      <tbody>
      <% fireEvents.forEach(function(e) { %>
        <tr>
          <td class="muted"><%= e.fired_at || e.scheduled_at %></td>
          <td>#<%= e.recurring_id %></td>
          <td>
            <% if (e.status === 'booked') { %><span class="pill ok">booked</span>
            <% } else if (e.status === 'no_time_available') { %><span class="pill warn">no_time_available</span>
            <% } else if (e.status === 'technical_error') { %><span class="pill err">technical_error</span>
            <% } else { %><span class="pill"><%= e.status %></span><% } %>
          </td>
          <td><%= e.court_booked || e.court_attempted || '—' %></td>
          <td class="muted"><%= e.latency_ms ? e.latency_ms + 'ms' : '' %></td>
        </tr>
      <% }) %>
      <% if (!fireEvents.length) { %><tr><td colspan="5" class="muted">No booking attempts yet.</td></tr><% } %>
      </tbody>
    </table>
  </div>
</div>

<div class="panel">
  <h2>Accounts</h2>
  <table>
    <thead><tr><th>#</th><th>Label</th><th>User</th><th>State</th><th>Last check</th></tr></thead>
      <tbody>
      <% accounts.forEach(function(a) { %>
        <tr>
          <td><%= a.id %></td>
          <td><%= a.label %></td>
          <td><%= a.username %></td>
          <td>
            <% var s = a.state || 'waiting'; %>
            <% var cls = 'ok'; if (['failed','technical_error','no_time_available','error','session_expired','login_required'].includes(s)) cls='err'; else if (['primed','attempting','first_immediate'].includes(s)) cls='warn'; else if (['token_ready','tested_ok'].includes(s)) cls='info'; %>
            <span class="pill <%= cls %>"><%= s %></span>
            <% if (a.state_msg) { %><div class="muted" style="font-size:11px;"><%= a.state_msg %></div><% } %>
          </td>
          <td class="muted"><%= a.last_check_at || '—' %></td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>

<div class="panel">
  <h2>Recent API calls</h2>
  <table>
    <thead><tr><th>Time</th><th>Account</th><th>Method</th><th>URL</th><th>Status</th><th>Latency</th></tr></thead>
    <tbody>
    <% recentAudit.forEach(function(a) { %>
      <tr>
        <td class="muted"><%= a.ts %></td>
        <td><%= a.account_id ? '#' + a.account_id : '' %></td>
        <td><%= a.method || '' %></td>
        <td class="muted"><%= a.url || '' %></td>
        <td><% if (a.status && a.status >= 400) { %><span class="pill err"><%= a.status %></span><% } else if (a.status) { %><span class="pill ok"><%= a.status %></span><% } else { %><span class="pill"><%= a.error || '' %></span><% } %></td>
        <td class="muted"><%= a.latency_ms ? a.latency_ms + 'ms' : '' %></td>
      </tr>
    <% }) %>
    </tbody>
  </table>
</div>
<%- include('partials/footer') %>

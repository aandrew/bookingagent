<%- include('partials/header', { title: 'Watches' }) %>
<div class="panel">
  <h2>Add watch</h2>
  <form id="addWatch" onsubmit="addWatch(event)">
    <div class="grid2">
      <div><label>Account</label>
        <select name="account_id" required>
          <% accounts.forEach(function(a) { %><option value="<%= a.id %>"><%= a.label %> (<%= a.username %>)</option><% }) %>
        </select>
      </div>
      <div><label>Label</label><input type="text" name="label" required></div>
      <div><label>Court (optional)</label><input type="text" name="court"></div>
      <div><label>Strategy</label>
        <select name="strategy"><option value="watch">watch</option><option value="scheduled">scheduled</option></select>
      </div>
      <div><label>Date (from)</label><input type="text" name="date_from" placeholder="YYYY-MM-DD"></div>
      <div><label>Date (to)</label><input type="text" name="date_to" placeholder="YYYY-MM-DD"></div>
      <div><label>Time start</label><input type="text" name="time_start" placeholder="HH:MM"></div>
      <div><label>Time end</label><input type="text" name="time_end" placeholder="HH:MM"></div>
      <div><label>Lead days</label><input type="number" name="lead_days" value="7"></div>
      <div><label>Duration (mins)</label><input type="number" name="duration_mins" value="60"></div>
    </div>
    <div style="margin-top: 10px;"><button type="submit">Add</button></div>
  </form>
</div>

<div class="panel">
  <h2>Watches</h2>
  <table>
    <thead><tr><th>#</th><th>Account</th><th>Label</th><th>Court</th><th>Window</th><th>Strategy</th><th>Status</th><th>Last run</th><th></th></tr></thead>
    <tbody>
    <% watches.forEach(function(w) { %>
      <tr>
        <td><%= w.id %></td>
        <td>#<%= w.account_id %></td>
        <td><%= w.label %></td>
        <td><%= w.court || '' %></td>
        <td class="muted"><%= w.date_from || '—' %> → <%= w.date_to || '—' %><br><%= w.time_start || '' %>–<%= w.time_end || '' %></td>
        <td><span class="pill"><%= w.strategy %></span></td>
        <td>
          <% if (w.last_status === 'booked') { %><span class="pill ok">booked</span>
          <% } else if (w.last_status === 'failed' || w.last_status === 'error') { %><span class="pill err"><%= w.last_status %></span>
          <% } else { %><span class="pill"><%= w.last_status || 'idle' %></span><% } %>
        </td>
        <td class="muted"><%= w.last_run_at || '—' %></td>
        <td>
          <button class="secondary" onclick="bookNow(<%= w.id %>)">Book now</button>
          <button class="danger" onclick="removeWatch(<%= w.id %>)">Delete</button>
        </td>
      </tr>
    <% }) %>
    </tbody>
  </table>
</div>

<script>
  async function jsonReq(url, opts) { const r = await fetch(url, { headers: { 'content-type': 'application/json' }, ...opts }); if (!r.ok) throw new Error((await r.json()).error || r.statusText); return r.json(); }
  async function addWatch(e) {
    e.preventDefault();
    const f = e.target;
    const body = {};
    for (const el of f.elements) if (el.name) body[el.name] = el.value;
    try { await jsonReq('/api/watches', { method: 'POST', body: JSON.stringify(body) }); location.reload(); }
    catch (e) { alert(e.message); }
  }
  async function bookNow(id) {
    try { const r = await jsonReq('/api/watches/' + id + '/book-now', { method: 'POST' }); alert('Book: ' + JSON.stringify(r)); }
    catch (e) { alert(e.message); }
  }
  async function removeWatch(id) {
    if (!confirm('Delete watch #' + id + '?')) return;
    try { await jsonReq('/api/watches/' + id, { method: 'DELETE' }); location.reload(); }
    catch (e) { alert(e.message); }
  }
</script>
<%- include('partials/footer') %>

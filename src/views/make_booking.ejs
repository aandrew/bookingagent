<%- include('partials/header', { title: 'Make Booking' }) %>
<style>
  .field-error { color: var(--err); font-size: 12px; margin-top: 4px; min-height: 14px; }
  .field-error:empty { display: none; }
  .help { color: var(--muted); font-size: 11px; margin-top: 2px; }
  .spinner { display: inline-block; width: 14px; height: 14px; border: 2px solid var(--muted); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite; vertical-align: -2px; margin-right: 8px; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .result-panel { margin-top: 14px; padding: 12px 14px; border-radius: 6px; display: none; }
  .result-panel.ok { background: rgba(94,224,167,.12); border: 1px solid var(--accent); color: var(--text); }
  .result-panel.err { background: rgba(224,108,117,.12); border: 1px solid var(--err); color: var(--text); }
  .result-panel h3 { margin: 0 0 6px; font-size: 14px; }
  .result-panel pre { background: #0a0c10; color: #cfd5dd; padding: 8px 10px; border-radius: 4px; margin: 6px 0 0; max-height: 200px; overflow: auto; font-size: 12px; }
  .time-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 6px; }
  .time-row select { width: 100%; }
  .dim { opacity: 0.5; pointer-events: none; }
</style>

<div class="panel">
  <h2>Make Booking</h2>
  <form id="addForm" onsubmit="return addBooking(event)">
    <div class="grid2">
      <div>
        <label>Account</label>
        <select name="account_id" id="account_id" required>
          <option value="">— pick an account —</option>
          <% accounts.forEach(function(a) { %><option value="<%= a.id %>"><%= a.label %> (<%= a.username %>)</option><% }) %>
        </select>
        <div class="help">Which Kooroo account to book under</div>
      </div>
      <div>
        <label>Court</label>
        <select name="court" id="court">
          <option value="">— any (auto-allocate) —</option>
          <option value="4">Court 4</option>
          <option value="5">Court 5</option>
          <option value="6">Court 6</option>
        </select>
        <div class="help">If you don't pick one, we'll assign the first free court for that time slot</div>
      </div>
      <div>
        <label>Date</label>
        <input type="date" name="date" id="date" required>
        <div class="help">Sydney date. The system auto-detects: today–7 days = book now, further = schedule.</div>
      </div>
      <div>
        <label>Start time (Sydney)</label>
        <div class="time-row">
          <select name="time_hour" id="time_hour" required>
            <% for (let h = 1; h <= 12; h++) { %><option value="<%= h %>" <%= h === 7 ? 'selected' : '' %>><%= h %></option><% } %>
          </select>
          <select name="time_minute" id="time_minute" required>
            <% for (const m of ['00','30']) { %><option value="<%= m %>" <%= m === '00' ? 'selected' : '' %>><%= m %></option><% } %>
          </select>
          <select name="time_ampm" id="time_ampm" required>
            <option value="AM">AM</option>
            <option value="PM" selected>PM</option>
          </select>
        </div>
        <div class="help">End time is computed from Duration below</div>
      </div>
      <div>
        <label>Duration (mins)</label>
        <input type="number" name="duration_mins" id="duration_mins" value="60" min="30" max="180" step="30" required>
        <div class="help">Length of the booking (end time = start time + duration)</div>
      </div>
      <div>
        <label>&nbsp;</label>
        <label style="display:inline-block; font-size: 14px; color: var(--text); margin: 0;">
          <input type="checkbox" id="makeRecurring">
          Make this a <strong>recurring</strong> weekly booking
        </label>
        <div class="help">When on, the booking recurs every 7 days from the picked date. When off, it's a one-time booking.</div>
      </div>
    </div>

    <div id="formError" class="field-error" style="margin-top: 10px;"></div>

    <div style="margin-top: 14px; display: flex; gap: 10px; align-items: center;">
      <button type="submit" id="submitBtn">Add booking</button>
      <span id="spinner" class="spinner" style="display: none;"></span>
      <span id="status" class="muted" style="font-size: 12px;"></span>
    </div>
  </form>

  <div id="result" class="result-panel"></div>
</div>

<script>
  const DAY_CODES = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  const MONTH_CODES = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

  // Convert (hour, minute, ampm) → 24h "HH:MM"
  function timeTo24(h, m, ap) {
    let hh = parseInt(h, 10) % 12;
    if (ap === 'PM') hh += 12;
    return String(hh).padStart(2, '0') + ':' + String(m).padStart(2, '0');
  }

  function buildLabel({ date, time }) {
    const t = formatTime12hFrom24(time);
    const [y, mo, d] = date.split('-').map(Number);
    return d + ' ' + MONTH_CODES[mo - 1] + ' ' + t;
  }
  function formatTime12hFrom24(hhmm) {
    const m = /^(\d{1,2}):(\d{2})$/.exec(String(hhmm || ''));
    if (!m) return hhmm;
    const h = parseInt(m[1], 10);
    const min = m[2];
    const ampm = h < 12 ? 'am' : 'pm';
    const h12 = ((h + 11) % 12) + 1;
    return min === '00' ? (h12 + ampm) : (h12 + ':' + min + ampm);
  }

  function showFieldError(id, msg) {
    const el = document.getElementById(id);
    if (el) el.textContent = msg || '';
  }
  function clearFieldErrors() {
    document.querySelectorAll('.field-error').forEach(e => e.textContent = '');
  }

  // Field validation (shared by both modes)
  function validate({ dateStr, timeStr, duration }) {
    if (!dateStr) return 'Date is required (use the calendar picker).';
    if (!/^\d{4}-\d{2}-\d{2}$/.test(dateStr)) return 'Date must be in YYYY-MM-DD format.';
    const today = new Date(); today.setHours(0,0,0,0);
    const d = new Date(dateStr + 'T00:00:00');
    if (isNaN(d.getTime())) return 'Date is not a real date.';
    if (d < today) return 'Date is in the past — pick today or later.';
    if (!/^\d{2}:\d{2}$/.test(timeStr)) return 'Time must be selected from the dropdowns.';
    if (!duration || duration < 30 || duration > 180) return 'Duration must be between 30 and 180 minutes.';
    return null;
  }

  function explainError(err, path) {
    let msg = err.message || String(err);
    if (/attempt to write a readonly database/i.test(msg)) {
      return 'The database is in read-only mode. Run `tools/deploy.sh` — it has a self-healing chown step.';
    }
    if (/court_pref must be one of/i.test(msg)) {
      return 'Invalid court preference.';
    }
    if (/day_of_week must be 0-6/i.test(msg)) {
      return 'Invalid day of week.';
    }
    if (/time must be HH:MM/i.test(msg)) {
      return 'Invalid time. Use the dropdowns, not free text.';
    }
    if (/no_courts_available/i.test(msg)) {
      return 'No courts available at this time slot — all 3 courts are taken by other recurring bookings.';
    }
    if (/no_time_available/i.test(msg)) {
      return 'The slot is not available on the Kooroo site. Someone else already booked it.';
    }
    if (/auth_required|session_expired|login_required/i.test(msg)) {
      return 'Your Kooroo session expired. Click "Re-login" on the Accounts page.';
    }
    return msg + (path ? '  (path: ' + path + ')' : '');
  }

  // v3.5: compute end time from start + duration (no more user-entered time_end)
  function endTime(start, durMins) {
    const [h, m] = start.split(':').map(Number);
    const total = h * 60 + m + durMins;
    const eh = Math.floor(total / 60) % 24;
    const em = total % 60;
    return String(eh).padStart(2, '0') + ':' + String(em).padStart(2, '0');
  }

  // v3.6: render result panels using DOM APIs (textContent + element
  // constructors) instead of innerHTML string concat. The watch.label
  // and attempt fields come from the server (which in turn reflects
  // Koorora's hardcoded error messages) — so practical XSS risk is low,
  // but defence-in-depth: never concatenate untrusted values into HTML.
  function setText(el, text) { el.textContent = text == null ? '' : String(text); }
  function p(text, opts) {
    const el = document.createElement('p');
    el.style.margin = '4px 0';
    setText(el, text);
    if (opts && opts.muted) el.className = 'muted';
    return el;
  }
  function pre(obj) {
    const el = document.createElement('pre');
    setText(el, JSON.stringify(obj, null, 2));
    return el;
  }
  function code(text) {
    const el = document.createElement('code');
    setText(el, text);
    return el;
  }
  function h3(prefix, labelText) {
    const el = document.createElement('h3');
    el.appendChild(document.createTextNode(prefix + ' '));
    const codeEl = document.createElement('code');
    setText(codeEl, labelText || '?');
    el.appendChild(codeEl);
    return el;
  }
  function linkP(text, href) {
    const el = document.createElement('p');
    el.style.margin = '4px 0';
    el.appendChild(document.createTextNode(text + ' '));
    const a = document.createElement('a');
    a.href = href;
    a.textContent = 'Current Bookings';
    el.appendChild(a);
    el.appendChild(document.createTextNode('.'));
    return el;
  }
  function clearChildren(el) { while (el.firstChild) el.removeChild(el.firstChild); }

  // Render a result panel for a one-off booking attempt
  function renderWatchResult(panel, r, watch) {
    const a = r.attempt || { status: 'unknown' };
    let cls, statusIcon, statusWord;
    if (a.status === 'booked')          { cls = 'ok';   statusIcon = '✓'; statusWord = 'Booking confirmed'; }
    else if (a.status === 'scheduled')  { cls = 'ok';   statusIcon = '⏱'; statusWord = 'Watcher scheduled'; }
    else if (a.status === 'no-match')   { cls = 'err';  statusIcon = '⚠'; statusWord = 'No open slot'; }
    else if (a.status === 'failed')     { cls = 'err';  statusIcon = '✗'; statusWord = 'Booking failed'; }
    else if (a.status === 'skipped')    { cls = 'err';  statusIcon = '⊘'; statusWord = 'Booking skipped'; }
    else if (a.status === 'error')      { cls = 'err';  statusIcon = '✗'; statusWord = 'Booking error'; }
    else                                { cls = 'err';  statusIcon = '?'; statusWord = 'Booking attempt returned status: ' + a.status; }
    panel.className = 'result-panel ' + cls;
    clearChildren(panel);
    panel.appendChild(h3(statusIcon + ' ' + statusWord + ' — label:', watch.label));
    if (a.status === 'booked') {
      const intro = document.createElement('p');
      intro.style.margin = '4px 0';
      intro.appendChild(document.createTextNode('Booked on Koorora at ' + (watch.time_start || '') + ' on ' + (watch.date_from || '') + '. Check '));
      const l = document.createElement('a');
      l.href = '/bookings';
      l.textContent = 'Current Bookings';
      intro.appendChild(l);
      intro.appendChild(document.createTextNode('.'));
      panel.appendChild(intro);
      panel.appendChild(pre(a));
    } else if (a.status === 'scheduled') {
      panel.appendChild(p(a.reason || 'Date is more than 7 days out. The system will fire this once when the booking window opens.'));
      const note = document.createElement('p');
      note.className = 'muted';
      note.style.fontSize = '12px';
      note.appendChild(document.createTextNode('The watcher fires '));
      const strong = document.createElement('strong');
      strong.textContent = 'once';
      note.appendChild(strong);
      note.appendChild(document.createTextNode(' and marks the booking as done — it will not be regularly rescheduled.'));
      panel.appendChild(note);
      panel.appendChild(pre(a));
    } else if (a.status === 'no-match') {
      panel.appendChild(p('Checked ' + (a.candidates ?? 0) + ' slots on ' + (watch.date_from || '') + ' — none were open at the requested time. The watcher is marked as fired (one-shot).'));
      panel.appendChild(pre(a));
    } else if (a.status === 'failed') {
      const errMsg = a.body?.message || a.error || 'unknown';
      const intro = p('Reason:');
      intro.appendChild(code(errMsg));
      panel.appendChild(intro);
      panel.appendChild(p('The watcher is marked as fired. Create a new one if you want to retry.', { muted: true }));
      panel.appendChild(pre(a));
    } else if (a.status === 'skipped') {
      panel.appendChild(p(a.error || 'account disabled or missing'));
      panel.appendChild(pre(a));
    } else if (a.status === 'error') {
      panel.appendChild(p(a.error || 'unknown'));
      panel.appendChild(pre(a));
    } else {
      panel.appendChild(pre(a));
    }
  }

  // Render a result panel for a recurring creation
  function renderRecurringResult(panel, r, label) {
    let cls = 'ok';
    if (r.last_status === 'failed' && r.last_error_category === 'no_courts_available') cls = 'err';
    panel.className = 'result-panel ' + cls;
    clearChildren(panel);
    panel.appendChild(h3('✓ Recurring scheduled — label:', r.label || label));
    const note = document.createElement('p');
    note.className = 'muted';
    note.style.fontSize = '12px';
    note.style.margin = '4px 0';
    note.appendChild(document.createTextNode('Every 7 days from the picked date. First fire at the opening (T-7d).'));
    if (r.court_auto_allocated && r.original_court_pref) {
      note.appendChild(document.createTextNode(' Court auto-allocated from C' + r.original_court_pref + ' → C' + r.court_pref + '.'));
    } else if (r.no_courts_available) {
      note.appendChild(document.createTextNode(' NO COURTS AVAILABLE: all 3 courts are taken by this time slot.'));
    } else if (r.first_occurrence_action === 'book_now') {
      note.appendChild(document.createTextNode(' First occurrence being attempted now.'));
    }
    panel.appendChild(note);
    panel.appendChild(pre(r));
  }

  async function addBooking(e) {
    e.preventDefault();
    clearFieldErrors();
    const result = document.getElementById('result');
    result.style.display = 'none';
    result.className = 'result-panel';

    const f = e.target;
    const recurringOn = !!f.makeRecurring?.checked;
    const dateStr = f.date.value;
    const time = timeTo24(f.time_hour.value, f.time_minute.value, f.time_ampm.value);
    const duration = parseInt(f.duration_mins.value, 10);

    const validationErr = validate({ dateStr, timeStr: time, duration });
    if (validationErr) {
      showFieldError('formError', validationErr);
      return false;
    }
    if (!f.account_id.value) {
      showFieldError('formError', 'Pick an account.');
      return false;
    }

    let body, path, label, isRecurring;

    if (recurringOn) {
      // Recurring: derive day_of_week from the picked date. The schedule is
      // "every 7 days from this date" — first fire = picked_date - 7d,
      // chain = previous slot's time = next slot's opening.
      const picked = new Date(dateStr + 'T12:00:00Z');
      const dayOfWeek = picked.getUTCDay();
      body = {
        account_id: parseInt(f.account_id.value, 10),
        day_of_week: dayOfWeek,
        time: time,
        court_pref: f.court.value || null,
        duration_mins: duration,
        first_slot_date: dateStr,
      };
      label = buildLabel({ date: dateStr, time });
      path = '/api/recurring';
      isRecurring = true;
    } else {
      // Non-recurring: one-time booking. The server decides whether to
      // attempt now (date ≤ 7 days) or schedule a watcher (date > 7 days).
      const end = endTime(time, duration);
      body = {
        account_id: parseInt(f.account_id.value, 10),
        date_from: dateStr,
        date_to: dateStr,
        time_start: time,
        time_end: end,
        duration_mins: duration,
        court: f.court.value || null,
      };
      label = buildLabel({ date: dateStr, time });
      path = '/api/watches';
      isRecurring = false;
    }

    const submitBtn = document.getElementById('submitBtn');
    const spinner = document.getElementById('spinner');
    const status = document.getElementById('status');
    submitBtn.disabled = true;
    submitBtn.classList.add('dim');
    spinner.style.display = 'inline-block';
    status.textContent = recurringOn ? 'Saving recurring booking…' : 'Saving booking…';
    document.getElementById('formError').textContent = '';

    try {
      const r = await jsonReq(path, { method: 'POST', body: JSON.stringify(body) });
      status.textContent = 'Saved.';
      result.style.display = 'block';
      if (isRecurring) {
        renderRecurringResult(result, r, label);
      } else {
        // /api/watches returns { watch, attempt }
        renderWatchResult(result, r, r.watch);
      }
      if (result.className.includes('ok')) {
        setTimeout(() => { location.href = '/bookings'; }, 2000);
      }
    } catch (e) {
      const friendly = explainError(e, path);
      status.textContent = 'Failed.';
      showFieldError('formError', friendly);
      result.style.display = 'block';
      result.className = 'result-panel err';
      result.innerHTML = '<h3>✗ Could not save booking</h3>'
        + '<p style="margin: 4px 0;">' + friendly + '</p>'
        + (e.message !== friendly ? '<pre>' + e.message + '</pre>' : '');
    } finally {
      submitBtn.disabled = false;
      submitBtn.classList.remove('dim');
      spinner.style.display = 'none';
    }
    return false;
  }
</script>
<%- include('partials/footer') %>
